# Copy to .env and fill in as needed. Sane local defaults are provided so
# `docker compose up` works out of the box with no cloud account required.

# --- App ---
AUTH_MODE=none
SECRET_KEY=dev-insecure-secret-change-me

# --- Database ---
POSTGRES_USER=agency
POSTGRES_PASSWORD=agency
POSTGRES_DB=agency
DATABASE_URL=postgresql+asyncpg://agency:agency@postgres:5432/agency

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM providers (add at least one to run agents) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional tool integrations (per-tool credentials, added as needed) ---
# TAVILY_API_KEY=
# SLACK_BOT_TOKEN=
# GITHUB_TOKEN=
